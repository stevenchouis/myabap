*&---------------------------------------------------------------------*
*& Report  ZR_TR17_CONTROL_FLOW
*& 練習 17：運算與流程控制（答案程式）
*&---------------------------------------------------------------------*
REPORT zr_tr17_control_flow.

DATA: gv_a      TYPE i VALUE 17,
      gv_b      TYPE i VALUE 5,
      gv_result TYPE i,
      gv_int    TYPE i,
      gv_dec    TYPE p LENGTH 8 DECIMALS 2,
      gv_score  TYPE i VALUE 75,
      gv_grade  TYPE c LENGTH 1,
      gv_sum    TYPE i,
      gv_loops  TYPE i,
      gv_n      TYPE i.

START-OF-SELECTION.
*----------------------------------------------------------------------*
* 1) 算術運算子：DIV = 整數商（捨去）、MOD = 餘數
*----------------------------------------------------------------------*
  gv_result = gv_a + gv_b.   WRITE: / '17 + 5 =', gv_result.
  gv_result = gv_a - gv_b.   WRITE: / '17 - 5 =', gv_result.
  gv_result = gv_a * gv_b.   WRITE: / '17 * 5 =', gv_result.
  gv_result = gv_a DIV gv_b. WRITE: / '17 DIV 5 =', gv_result.
  gv_result = gv_a MOD gv_b. WRITE: / '17 MOD 5 =', gv_result.

*----------------------------------------------------------------------*
* 2) 目的地型別決定精度：存 i 四捨五入、存 p 保留小數
*----------------------------------------------------------------------*
  gv_int = gv_a / gv_b.
  gv_dec = gv_a / gv_b.
  WRITE: / '存進 i：', gv_int,
         / '存進 p：', gv_dec.

*----------------------------------------------------------------------*
* 3) IF/ELSEIF/ELSE：條件從嚴排到寬，第一個成立就跳出
*----------------------------------------------------------------------*
  IF gv_score >= 80.
    gv_grade = 'A'.
  ELSEIF gv_score >= 60.
    gv_grade = 'B'.
  ELSE.
    gv_grade = 'C'.
  ENDIF.
  WRITE: / gv_score, '分 → 等第', gv_grade.

*----------------------------------------------------------------------*
* 4) CASE：離散值分支；WHEN OTHERS 接住預期外的值
*----------------------------------------------------------------------*
  CASE gv_grade.
    WHEN 'A'.
      WRITE / '優等'.
    WHEN 'B' OR 'C'.
      WRITE / '普通'.
    WHEN OTHERS.
      WRITE / '資料異常'.
  ENDCASE.

*----------------------------------------------------------------------*
* 5) DO n TIMES：圈數在 sy-index
*----------------------------------------------------------------------*
  DO 5 TIMES.
    WRITE: / '第', sy-index, '圈'.
  ENDDO.

*----------------------------------------------------------------------*
* 6) 無上限 DO + EXIT：一定要有出口，否則 TIME_OUT
*----------------------------------------------------------------------*
  gv_sum = 0.
  DO.
    gv_sum = gv_sum + sy-index.
    IF gv_sum > 100.
      gv_loops = sy-index.
      EXIT.                       " 跳出整個迴圈
    ENDIF.
  ENDDO.
  WRITE: / '累加超過 100：總和', gv_sum, '，最後圈數', gv_loops.

*----------------------------------------------------------------------*
* 7) WHILE：前測式迴圈
*----------------------------------------------------------------------*
  gv_n = 1.
  WHILE ( gv_n + 1 ) * ( gv_n + 1 ) <= 200.
    gv_n = gv_n + 1.
  ENDWHILE.
  WRITE: / '平方不超過 200 的最大整數：', gv_n.

*----------------------------------------------------------------------*
* 8) CHECK：條件「不成立」就跳下一圈（＝過濾器）
*----------------------------------------------------------------------*
  DO 10 TIMES.
    CHECK sy-index MOD 2 = 0.
    WRITE: / '偶數：', sy-index.
  ENDDO.
